# Code repos manage their own git history
repos/*
!repos/.gitkeep

# Secrets — per-collaborator
.mcp.json

# Dispatch runtime
ralph/dispatch.log
ralph/*.pid

# OS junk
.DS_Store
*.swp

# Editor junk
.idea/
.vscode/

# Ralph — ignore everything except key files
.ralph/*
!.ralph/fix_plan.md
!.ralph/PROMPT.md
!.ralph/PROMPT_PLAN.md
!.ralph/constitution.md

# General logs
*.log

# OS files
Thumbs.db

# Temporary files
*.tmp
.temp/

# Node modules
node_modules/

# Environment files
.env
.env.local
.env.*.local

# Build outputs
dist/
/out/
*.tsbuildinfo

# Vite
*.local

# IDE files
*.swo

# Ralph backup directories (created by migration)
.ralph_backup_*

# Jekyll local-build artifacts (docs/)
docs/_site/
docs/_site_local/
docs/_site_inv/
docs/_site_default/
docs/.jekyll-cache/
docs/.bundle/
docs/vendor/
docs/Gemfile.lock
