# Code repos manage their own git history
repos/*
!repos/.gitkeep

# Secrets — per-collaborator
.mcp.json

# Dispatch runtime
ralph/dispatch.log
ralph/*.pid

# OS junk
.DS_Store
*.swp
Thumbs.db

# Editor junk
.idea/
.vscode/
*.swo

# General logs
*.log

# Temporary files
*.tmp
.temp/

# Node modules
node_modules/

# Environment files
.env
.env.local
.env.*.local

# Build outputs
dist/
/out/
*.tsbuildinfo

# Python bytecode (steering scripts)
__pycache__/
*.pyc

# Vite
*.local

# Ralph — ignore everything except key files
.ralph/*
!.ralph/fix_plan.md
!.ralph/PROMPT.md
!.ralph/PROMPT_PLAN.md
!.ralph/constitution.md

# Ralph backup directories (created by migration)
.ralph_backup_*

# Ralph machine-specific config (sourced by ralph_loop.sh load_ralphrc)
.ralphrc

# Jekyll local-build artifacts (docs/)
docs/_site/
docs/_site_local/
docs/_site_inv/
docs/_site_default/
docs/.jekyll-cache/
docs/.bundle/
docs/vendor/
docs/Gemfile.lock
