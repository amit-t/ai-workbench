# Code repos manage their own git history
repos/*
!repos/.gitkeep

# Secrets — per-collaborator
.mcp.json

# Dispatch runtime
ralph/dispatch.log
ralph/*.pid

# OS junk
.DS_Store
*.swp

# Editor junk
.idea/
.vscode/

# Jekyll build output
docs/_site/
docs/.jekyll-cache/

# Ralph — ignore everything except key files
.ralph/*
!.ralph/fix_plan.md
!.ralph/PROMPT.md
!.ralph/PROMPT_PLAN.md
!.ralph/constitution.md

# Ralph machine-specific config (sourced by ralph_loop.sh load_ralphrc)
.ralphrc
